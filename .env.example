# ============================================================
# QMT Bridge 配置文件模板
# 复制此文件为 .env 并填写你自己的配置:
#   cp .env.example .env
# ============================================================

# ===== 服务端配置 (Windows 端，运行 server.py) =====
# 服务监听地址 (通常为 0.0.0.0)
SERVER_HOST=0.0.0.0
# 服务监听端口
SERVER_PORT=8888
# MiniQMT 本地数据路径 (必填)
QMT_PATH=<your_qmt_userdata_mini_path>
# 资金账号 (必填)
ACCOUNT_ID=<your_account_id>
# 认证 TOKEN (必填，客户端服务端需一致)
TOKEN=<your_token>

# ===== 客户端配置 (任意端，运行 client.py / 测试) =====
# Windows 服务端 IP 地址 (必填)
CLIENT_HOST=<your_windows_ip>
# 服务端端口
CLIENT_PORT=8888

# ===== 测试配置 =====
# 测试用股票代码
TEST_STOCK_CODE=000001.SZ
# K线周期: 1m/5m/15m/30m/60m/1d/1w/1mon
TEST_PERIOD=1d
# 开始日期 YYYYMMDD
TEST_START_TIME=20250501
# 结束日期 YYYYMMDD
TEST_END_TIME=20250531
# 交易测试会话 ID
TEST_SESSION_ID=123456
# 账户类型: STOCK / FUTURES / CREDIT
TEST_ACCOUNT_TYPE=STOCK
